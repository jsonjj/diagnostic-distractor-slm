# Secrets
.env

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# Data: keep raw Kaggle competition CSVs out of git; commit our derived/processed dataset.
data/raw/*
!data/raw/.gitkeep

# Model artifacts
adapters/
merged/
outputs/
*.gguf
wandb/
/qwen3-8b-distractor-lora-v8.zip

# Wayline packaged runtime and local learner state
/.venv-live/
/services/wayline_forge/build/
/services/wayline_forge/dist/
/services/wayline_forge/runtime/logs/
/services/wayline_forge/runtime/profiles/
*.sqlite-wal
*.sqlite-shm

# Wayline local llama.cpp toolchain/build (arm64 llama-server; large, reproducible)
/.wayline-build/

# Wayline Unity generated state and local builds
/unity/Wayline/Library/
/unity/Wayline/Temp/
/unity/Wayline/Logs/
/unity/Wayline/obj/
/unity/Wayline/UserSettings/
/unity/Wayline/Builds/

# Eval artifacts. Canonical, version-tagged predictions (predictions_<role>_<version>.jsonl
# and predictions_frontier*.jsonl) ARE committed so every reported eval number is reproducible.
# Only the notebook's transient, un-versioned run outputs + smoke files stay out of git.
# Anchored to repo root so committed datasets under data/processed/ are untouched.
/predictions_base.jsonl
/predictions_tuned.jsonl
/*_smoke.jsonl

# Glitch Rally offline-generation transfer artifacts (reviewed sanitized packs only).
/glitch_rally_colab_bundle.zip
/glitch_rally_raw_candidates_v1.jsonl
/glitch_rally_generation_run_v1.json
/data/game/work/

# Private owner-only holdout unblinding material (never publish).
/data/eval_out/OWNER_ONLY_DO_NOT_OPEN_UNTIL_REVIEW_COMPLETE.json

# OS
.DS_Store

# Local AI/editor configuration
/.cursor/
/.claude/settings.local.json

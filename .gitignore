# Secrets
.env

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# Data: keep raw Kaggle competition CSVs out of git; commit our derived/processed dataset.
data/raw/*
!data/raw/.gitkeep

# Model artifacts
adapters/
merged/
outputs/
*.gguf
wandb/

# Eval artifacts. Canonical, version-tagged predictions (predictions_<role>_<version>.jsonl
# and predictions_frontier*.jsonl) ARE committed so every reported eval number is reproducible.
# Only the notebook's transient, un-versioned run outputs + smoke files stay out of git.
# Anchored to repo root so committed datasets under data/processed/ are untouched.
/predictions_base.jsonl
/predictions_tuned.jsonl
/*_smoke.jsonl

# OS
.DS_Store

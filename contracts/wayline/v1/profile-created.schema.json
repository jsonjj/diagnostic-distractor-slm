{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wayline.game/contracts/v1/profile-created.schema.json",
  "title": "Wayline Profile Created",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId", "createdAtUtc"],
  "properties": {
    "schemaVersion": {"const": "wayline.v1"},
    "profileId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,95}$"
    },
    "createdAtUtc": {
      "type": "string",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\d(?:\\.\\d{6})?Z$"
    }
  }
}

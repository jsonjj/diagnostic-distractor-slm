{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wayline.game/contracts/v1/progression-shared.schema.json",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,95}$"
    },
    "displayText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "feedbackText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "confidence": {
      "enum": ["certain", "leaning", "guessing"]
    },
    "publicOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optionId", "displayText"],
      "properties": {
        "optionId": {"$ref": "#/$defs/identifier"},
        "displayText": {"$ref": "#/$defs/displayText"}
      }
    },
    "trustedSteps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {"$ref": "#/$defs/feedbackText"}
    }
  }
}

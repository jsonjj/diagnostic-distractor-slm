{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wayline.game/contracts/v1/wrong-count-result.schema.json",
  "title": "Wayline Wrong Count Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "batchId", "itemCount", "wrongCount", "revisionRequired"],
  "properties": {
    "schemaVersion": {"const": "wayline.v1"},
    "batchId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,95}$"
    },
    "itemCount": {"type": "integer", "minimum": 3, "maximum": 10},
    "wrongCount": {"type": "integer", "minimum": 0, "maximum": 10},
    "revisionRequired": {"type": "boolean"}
  }
}

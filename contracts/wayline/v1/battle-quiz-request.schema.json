{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wayline.game/contracts/v1/battle-quiz-request.schema.json",
  "title": "Wayline Battle Quiz Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "sessionId", "battleId", "worldId", "battleTier"],
  "properties": {
    "schemaVersion": {"const": "wayline.v1"},
    "requestId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,95}$"
    },
    "sessionId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,95}$"
    },
    "battleId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,95}$"
    },
    "worldId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,95}$"
    },
    "battleTier": {
      "type": "string",
      "enum": ["route_1", "route_2", "route_3", "elite", "world_boss", "campaign_finale", "seal_trial"]
    }
  }
}

# Copy this file to .env and fill in your keys. .env is gitignored.

# TrueFoundry AI Gateway (OpenAI-compatible).
# TFY_MODEL preserves the reproducible Sonnet baseline; role overrides select Opus.
# Non-empty values in this project-local file override stale inherited TFY_* values.
TFY_BASE_URL=https://tfy-eu.promptlens.trilogy.com
TFY_MODEL=claude-sonnet-5
TFY_TEACHER_MODEL=anthropic-primary/claude-opus-4-8
TFY_JUDGE_MODEL=anthropic-primary/claude-opus-4-8
TFY_FRONTIER_MODEL=anthropic-primary/claude-opus-4-8
TFY_API_KEY=your-truefoundry-pat-here

# Hugging Face (needed Day 5 to publish dataset + model)
HF_TOKEN=your-hf-write-token-here
